#!/usr/bin/env bash

# runs any git command on all local repos in the current directory. Default is:
# - check github for all missing repos by the org and clone them locally
# - pull on the current branch
#
# setup:
# - export GITHUB_TOKEN=ghp_your_github_token_here
# - add the name of the org to .gitreposteam (current directory)
# - add the list of repos you don't want to clone or operate on in
#   .gitreposignore (current directory)
# - let'er rip

if [[ -n "${DEBUG}" ]]; then
    exec 5> /tmp/bash_debug_output.txt
    BASH_XTRACEFD="5"
    PS4='$LINENO: '
    set -x -T
fi

function usage()
{
    cat << EOF
Usage: $(basename "${0}") [OPTION]...
Options: -f: update dirty repos
         -h: show this help dialog
         -t ARG: specify team name
         -C ARG: specify rootdir
         -- ARG1 [ARG2 ...]: arguments run by git instead of "git pull"

This script will automatically clone missing repositories from the organization
and update existing repositories. Use .gitreposteam to specify the organization
and .gitreposignore to exclude specific repositories.
EOF
}

function elem_in()
{
    local e match="$1"
    shift
    for e; do [[ "${e}" == "${match}" ]] && return 0; done
    return 1
}

# https://github.com/jrabinow/dotfiles/blob/6e821e959b5261f2db43cde1b10d40c689f5e33e/.config/git/config#L28
function get_github_token()
{
    git config --get-all credential.helper \
        | awk '/store --file/ {print $NF}' \
        | xargs -I% sh -c "cat %" \
        | sed -n 's|https://[^:]*:\([^@]*\)@github.com|\1|p'
}

# python requests version: https://stackoverflow.com/a/63720399
# conversion to curl by dumping python: https://stackoverflow.com/a/16630836
function github_authheader()
{
    local orgname="${1}"
    shift
    local github_token="${1}"
    shift
    echo "Authorization: Bearer ${github_token}"
}

function run_git_cmd()
{
    gitargs="${*}"
    # we intentionally do not quote the gitargs variable below to allow word
    # splitting
    # shellcheck disable=SC2086
    out=$(printf "=========== UPDATING REPO %s ===========\n" "${subdir}" \
        && printf "%s: " "${subdir}" \
        && git ${gitargs} 2>&1)
    stdbuf -o20K -e20K echo "${out}"
}

function update_existing_repos()
{
    local rootdir="${1}"
    shift
    local force_dirty="${1}"
    shift
    local gitargs="${*}"

    for subdir in *; do
        {
            test -d "${subdir}/.git" && ! elem_in "${subdir}" "${IGNORE_REPOS[@]}"
        } || continue
        cd "${subdir}"
        local repostatus
        if "${force_dirty}"; then
            run_git_cmd "${gitargs}" &
        else
            repostatus=$(git status --short | grep -v '^??' || true)
            if [[ -z "${repostatus}" ]]; then
                run_git_cmd "${gitargs}" &
            else
                printf "\033[31m=========== DIRTY REPO %s ==========\033[0m\n" "${subdir}"
            fi
        fi
        cd "${rootdir}"
    done
}

# Lists all repositories for a GitHub organization using GraphQL API
# Usage: list_all_repos_for_org <orgname>
# Returns: List of SSH clone URLs for all repositories in the organization
function list_all_repos_for_org()
{
    local cursor=null
    local hasNextPage=true
    local orgname="${1}"; shift
    local token
    local authheader
    local query
    local response
    local repos

    token="$(get_github_token)"
    authheader="$(github_authheader "${orgname}" "${token}")"

    while [[ "${hasNextPage}" = true ]]; do
        query=$(jq -n --arg org "${orgname}" --argjson cursor "${cursor}" '{
            query: "
              query($org: String!, $cursor: String) {
                organization(login: $org) {
                  repositories(first: 100, after: $cursor) {
                    pageInfo {
                      hasNextPage
                      endCursor
                    }
                    nodes {
                      name
                      url
                      sshUrl
                    }
                  }
                }
              }
            ",
            variables: {
                org: $org,
                cursor: $cursor
            }
        }')

        response=$(curl -s --fail-with-body -X POST \
            -H "${authheader}" \
            -H "Content-Type: application/json" \
            -H "X-GitHub-Api-Version: 2022-11-28" \
            https://api.github.com/graphql \
            --data "${query}")

        # Check for errors in the response
        if echo "${response}" | jq -e '.errors' > /dev/null 2>&1; then
            echo "Error in GraphQL response:" >&2
            echo "${response}" | jq '.errors' >&2
            return 1
        fi

        # Extract repository information (SSH URLs for cloning)
        repos=$(echo "${response}" | jq -r '.data.organization.repositories.nodes[] | .sshUrl')
        echo "${repos}"

        # Update pagination variables
        hasNextPage=$(echo "${response}" | jq -r '.data.organization.repositories.pageInfo.hasNextPage')
        cursor=$(echo "${response}" | jq -r '.data.organization.repositories.pageInfo.endCursor')

        # Handle null cursor - convert string "null" to actual null for jq
        if [[ "${cursor}" = "null" ]]; then
            cursor=null
        else
            cursor="\"${cursor}\""
        fi
    done
}

function clone_any_missing_repos()
{
    local orgname="${1}"
    local repo_urls
    local dirname

    readonly orgname

    repo_urls="$(list_all_repos_for_org "${orgname}")"

    for repo_url in ${repo_urls}; do
        # Extract directory name from SSH URL (git@github.com:org/repo.git -> repo)
        dirname="$(basename "${repo_url}" .git)"

        if [[ ! -d "${dirname}" ]] && ! elem_in "${dirname}" "${IGNORE_REPOS[@]}"; then
            echo "MISSING ${dirname}; cloning from ${repo_url}"
            git clone "${repo_url}"
        fi
    done
}

function main()
{
    local ROOTDIR=.
    local team_name_isset=false
    local FORCE_DIRTY=false
    local GITARGS=""

    local IGNORE_REPOS

    while getopts "Cfht-" opt; do
        case "${opt}" in
            C)
                ROOTDIR="${!OPTIND}"
                OPTIND=$((OPTIND + 1))
                ;;
            f) # force operation on dirty repos
                FORCE_DIRTY=true
                shift
                ;;
            h) # help message
                usage
                exit 0
                ;;
            t)
                TEAM_NAME="${!OPTIND}"
                OPTIND=$((OPTIND + 2))
                team_name_isset=true
                ;;
            -)
                GITARGS="${*}"
                shift $#
                ;;
            *)
                printf "Unknown option, exiting now\n" >&2
                exit 1
                ;;
        esac
    done

    shift $((OPTIND - 1))
    [[ ${1:-} == '--' ]] && shift

    if [[ $# -ge 1 ]] || [[ -z "${GITARGS}" ]]; then
        GITARGS="${*:-pull}"
    fi

    if [[ "${ROOTDIR}" == "." ]]; then
        dirpath=.
        while
            [[ "${dirpath}" != "/" ]] \
                && [[ ! -f "${dirpath}/.gitreposteam" ]] \
                && [[ ! -f "${dirpath}/.gitreposignore" ]]
        do
            dirpath="$(realpath "${dirpath}/..")"
        done
        if [[ "${dirpath}" == / || "${dirpath}" == "." ]]; then
            dirpath="$(pwd)"
        fi
        ROOTDIR="${dirpath}"
    fi

    cd "${ROOTDIR}"

    if [[ -f .gitreposignore ]]; then
        mapfile -t IGNORE_REPOS < .gitreposignore
    else
        IGNORE_REPOS=()
    fi
    if ! "${team_name_isset}"; then
        if [[ -f .gitreposteam ]]; then
            TEAM_NAME="$(cat .gitreposteam)"
        else
            TEAM_NAME="UNKNOWN"
        fi
    fi

    readonly FORCE_DIRTY
    readonly GITARGS
    readonly ROOTDIR
    readonly TEAM_NAME
    readonly IGNORE_REPOS

    # Always clone missing repositories first
    if [[ "${GITARGS}" == "pull" ]]; then
        clone_any_missing_repos "${TEAM_NAME}"
    fi

    # Then update existing repositories
    update_existing_repos "${ROOTDIR}" "${FORCE_DIRTY}" "${GITARGS}"

    # jobs -p returns list of children as pids, one per line. Don't quote
    # shellcheck disable=SC2046
    wait $(jobs -p)
}

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
    set -e -u
    set -o pipefail
    main "$@"
fi
