#!/usr/bin/env bash

if [ -n "${DEBUG}" ]; then
    exec 5> /tmp/bash_debug_output.txt
    BASH_XTRACEFD="5"
    PS4='$LINENO: '
    set -x -T
fi


PASTE_PROVIDER=pasters
BACKENDS=(pasters cnet)

function usage()
{
    cat << EOF
Usage: ${0##*/} [OPTION]... get PASTE_ID
Usage: ${0##*/} [OPTION]... post [FILE]
Usage: ${0##*/} [OPTION]... delete PASTE_ID|URL
Options: --help, -h: show this help dialog
         --backend BACKEND, -b BACKEND: select paste backend (default: ${PASTE_PROVIDER})
                   Available backends: ${BACKENDS[*]}
When posting, FILE argument is optional. If not provided, wwwpaste will read stdin
EOF
}

function to_clipboard()
{
    case "${OSTYPE}" in
        darwin*)
            pbcopy
            pbpaste
            ;;
        *)
            tee
    esac
}

function pasters_get()
{
    local id="${1##https://paste.rs/}"
    shift
    curl "https://paste.rs/${id}"
}

function pasters_post()
{
    if [ "${#}" -eq 0 ]; then
        curl -s -X POST "https://paste.rs/" --data-binary @- \
            | to_clipboard
    else
        local file="${1}"
        shift
        test -r "${file}" \
            && curl -s -X POST "https://paste.rs/" --data-binary "@${file}" \
            | to_clipboard
    fi
    printf "\n"
}

function pasters_del()
{
    local id="${1##https://paste.rs/}"
    shift
    curl -X DELETE "https://paste.rs/${id}"
}

# https://paste.c-net.org
function cnet_get()
{
    local url="${1}"
    shift
    curl -s "${url}"
}

function cnet_post()
{
    if [ "${#}" -eq 0 ]; then
        curl -s --data-binary @- https://paste.c-net.org/ \
            | to_clipboard
    else
        local file="${1}"
        shift
        test -r "${file}" \
            && curl -s --data-binary "@${file}" https://paste.c-net.org/ \
            | to_clipboard
    fi
}

function cnet_del()
{
    printf 'Deletion is not supported by paste.c-net.org\n' >&2
    return 1
}

function main()
{
    while getopts "hb:-:" opt; do
        case ${opt} in
            h) # help message
                usage
                exit 0
                ;;
            b)
                PASTE_PROVIDER="${OPTARG}"
                ;;
            -)
                case "${OPTARG}" in
                    help)
                        usage
                        exit 0
                        ;;
                    backend)
                        PASTE_PROVIDER="${!OPTIND}"
                        OPTIND=$((OPTIND + 1))
                        ;;
                    *)
                        printf 'Unknown option, exiting now\n' >&2
                        exit 1
                        ;;
                esac
                ;;
            ?)
                printf 'Unknown option, exiting now\n' >&2
                exit 1
                ;;
        esac
    done
    shift $((OPTIND - 1))
    [[ ${1-} == '--' ]] && shift

    local action="${1}"
    shift

    local fn_prefix
    case "${PASTE_PROVIDER}" in
        pasters)
            fn_prefix=pasters
            ;;
        cnet)
            fn_prefix=cnet
            ;;
        *)
            printf 'Unknown backend: %s\nAvailable backends: %s\n' "${PASTE_PROVIDER}" "${BACKENDS[*]}" >&2
            exit 1
            ;;
    esac

    case "${action}" in
        get)
            "${fn_prefix}_get" "${@}"
            ;;
        post)
            "${fn_prefix}_post" "${@}"
            ;;
        del*)
            "${fn_prefix}_del" "${@}"
            ;;
        *)
            usage
            ;;
    esac
}

if [ "${BASH_SOURCE[0]}" == "$0" ]; then
    set -e -u
    set -o pipefail
    main "$@"
fi
